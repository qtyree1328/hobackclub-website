---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  heroClass?: string;
}

const { title, description = 'Hoback Club — A luxury private club in Jackson Hole, Wyoming.', heroClass = '' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Hoback Club</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lato:wght@100;300;400;700;900&family=Cormorant+Garamond:wght@300;400;600&display=swap" rel="stylesheet" />
  <slot name="head" />
</head>
<body class={heroClass}>
  <Nav />
  <main>
    <slot />
  </main>
  <Footer />
  <slot name="scripts" />
</body>
</html>
