---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroStandard from '../components/HeroStandard.astro';
import { withBase } from '../utils/paths';
---

<BaseLayout title="Amenities" description="Explore Hoback Club's world-class amenities, from The Great Hall to our spa, fitness center, and family-friendly activities.">
  <!-- HERO SECTION -->
  <HeroStandard title="Amenities" imageId="100067" height="70vh" />

  <!-- INTRO SECTION -->
  <section class="intro-section">
    <div class="intro-container">
      <h2>Everything You Need, All Under One Roof</h2>
      <p>
        Hoback Club offers comprehensive amenities designed for luxury, wellness, adventure, and family connection. From our award-winning restaurant and full-service spa to world-class fitness facilities and year-round activities, every detail is crafted to elevate your alpine experience.
      </p>
    </div>
  </section>

  <!-- AMENITY BLOCKS SECTION -->
  <section class="amenities-section">
    <!-- BLOCK 1: The Great Hall (image left) -->
    <div class="amenity-block from-left">
      <div class="amenity-image">
        <img src="https://hobackclub.com/images/dynamic/getImage.gif?ID=100083" alt="The Great Hall restaurant" />
      </div>
      <div class="amenity-text">
        <h3>The Great Hall</h3>
        <p>
          Our full-service restaurant celebrates the finest in alpine dining. Featuring locally sourced ingredients, seasonal menus, and craft cocktails curated by award-winning mixologists. Whether it's an intimate dinner or a grand celebration, The Great Hall is the heart of our culinary experience.
        </p>
        <ul class="amenity-features">
          <li>— Locally sourced seasonal menus</li>
          <li>— Award-winning chef & sommelier</li>
          <li>— Private dining available</li>
          <li>— Full bar with craft cocktails</li>
        </ul>
      </div>
    </div>

    <!-- BLOCK 2: Wellness & Recovery Spa (image right) -->
    <div class="amenity-block from-right reverse">
      <div class="amenity-image">
        <img src="https://hobackclub.com/images/dynamic/getImage.gif?ID=100085" alt="Wellness spa" />
      </div>
      <div class="amenity-text">
        <h3>Wellness & Recovery Spa</h3>
        <p>
          Rejuvenate at our full-service spa designed for alpine recovery and wellness. From therapeutic massage and body treatments to steam rooms and saunas, our spa sanctuary provides the perfect complement to an active mountain lifestyle.
        </p>
        <ul class="amenity-features">
          <li>— Therapeutic massage & bodywork</li>
          <li>— Recovery treatments</li>
          <li>— Steam room & sauna</li>
          <li>— Relaxation lounge</li>
        </ul>
      </div>
    </div>

    <!-- BLOCK 3: Fitness Center (image left) -->
    <div class="amenity-block from-left">
      <div class="amenity-image">
        <img src="https://hobackclub.com/images/dynamic/getImage.gif?ID=100087" alt="Fitness center" />
      </div>
      <div class="amenity-text">
        <h3>Fitness Center</h3>
        <p>
          Our state-of-the-art fitness facility features premium equipment, group classes, personal training, and a dedicated yoga studio. Maintain your fitness routine year-round while enjoying mountain views and personalized coaching from certified trainers.
        </p>
        <ul class="amenity-features">
          <li>— Premium cardio & strength equipment</li>
          <li>— Personal training available</li>
          <li>— Yoga & group fitness classes</li>
          <li>— Mountain-view fitness studio</li>
        </ul>
      </div>
    </div>

    <!-- BLOCK 4: Ski Valet & Equipment (image right) -->
    <div class="amenity-block from-right reverse">
      <div class="amenity-image">
        <img src="https://hobackclub.com/images/dynamic/getImage.gif?ID=100088" alt="Ski valet service" />
      </div>
      <div class="amenity-text">
        <h3>Ski Valet & Equipment</h3>
        <p>
          Enjoy seamless access to Jackson Hole Mountain Resort with our complimentary ski valet service. Boot warming, equipment storage, and expert guidance are just steps from the tram. More time skiing, less time managing gear.
        </p>
        <ul class="amenity-features">
          <li>— Complimentary ski valet</li>
          <li>— Boot warming & drying</li>
          <li>— Equipment storage & tuning</li>
          <li>— Steps from the tram</li>
        </ul>
      </div>
    </div>

    <!-- BLOCK 5: Pool & Hot Tubs (image left) -->
    <div class="amenity-block from-left">
      <div class="amenity-image">
        <img src="https://hobackclub.com/images/dynamic/getImage.gif?ID=100089" alt="Pool and hot tubs" />
      </div>
      <div class="amenity-text">
        <h3>Pool & Hot Tubs</h3>
        <p>
          Soak in heated outdoor hot tubs while gazing at mountain vistas, or swim in our year-round heated pool. Poolside service, cabanas, and fire pits create the perfect gathering spot for relaxation and community.
        </p>
        <ul class="amenity-features">
          <li>— Heated outdoor pool</li>
          <li>— Multiple hot tubs</li>
          <li>— Poolside cabanas</li>
          <li>— Fire pits & lounge seating</li>
        </ul>
      </div>
    </div>

    <!-- BLOCK 6: Kids' Programs (image right) -->
    <div class="amenity-block from-right reverse">
      <div class="amenity-image">
        <img src="https://hobackclub.com/images/dynamic/getImage.gif?ID=100091" alt="Kids activities" />
      </div>
      <div class="amenity-text">
        <h3>Kids' Programs</h3>
        <p>
          Create lasting family memories with our comprehensive kids' programming. Supervised activities, game rooms, movie nights, and family-friendly adventures ensure children discover the magic of alpine living year-round.
        </p>
        <ul class="amenity-features">
          <li>— Supervised activities & programs</li>
          <li>— Game room & entertainment</li>
          <li>— Family movie nights</li>
          <li>— Seasonal adventures</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- QUICK REFERENCE CARDS SECTION -->
  <section class="cards-section">
    <div class="cards-container">
      <h2 class="section-title">Amenity Highlights</h2>
      <div class="cards-grid">
        <div class="amenity-card">Ski Valet</div>
        <div class="amenity-card">Heated Pool</div>
        <div class="amenity-card">Hot Tubs</div>
        <div class="amenity-card">Spa & Wellness</div>
        <div class="amenity-card">Fitness Center</div>
        <div class="amenity-card">The Great Hall</div>
        <div class="amenity-card">Après Ski Lounge</div>
        <div class="amenity-card">Kids' Program</div>
        <div class="amenity-card">Concierge</div>
        <div class="amenity-card">Boot Warming</div>
        <div class="amenity-card">Equipment Storage</div>
        <div class="amenity-card">Mountain Views</div>
      </div>
    </div>
  </section>

  <!-- PARALLAX DIVIDER SECTION -->
  <section class="parallax-section">
    <div class="parallax-bg" style="background-image: url('https://hobackclub.com/images/dynamic/getImage.gif?ID=100099');"></div>
    <div class="parallax-overlay"></div>
  </section>

  <!-- FINAL CTA SECTION -->
  <section class="final-cta-section">
    <div class="final-cta-container">
      <h2>Experience Hoback Club</h2>
      <a href={withBase('/stay')} class="btn btn--primary">Plan Your Stay</a>
    </div>
  </section>

  <slot name="scripts">
    <script>
      // Intersection Observer for scroll reveal
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, { threshold: 0.15 });

      document.querySelectorAll('.amenity-block').forEach((el) => {
        observer.observe(el);
      });

      // Scroll reveal for sections
      const sectionObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('reveal');
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.intro-section, .cards-section, .final-cta-section').forEach((el) => {
        sectionObserver.observe(el);
      });
    </script>
  </slot>
</BaseLayout>

<style>
  :global(:root) {
    --ink: #1e2d3a;
    --tan: #ede9e1;
    --paper: #f7f5f2;
    --text: #272f36;
    --text-secondary: #666;
    --accent-gray: #7a8d98;
    --divider: #e8e4df;
    --hover: #365e75;
  }

  /* INTRO SECTION */
  .intro-section {
    background: white;
    padding: 80px 40px;
    opacity: 0;
    transition: opacity 0.8s ease;
  }

  .intro-section.reveal {
    opacity: 1;
  }

  .intro-container {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .intro-section h2 {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 2.4rem;
    font-weight: 300;
    color: var(--ink);
    margin-bottom: 24px;
    letter-spacing: 0.05em;
  }

  .intro-section p {
    font-family: 'Lato', Helvetica, Arial, sans-serif;
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  /* AMENITY BLOCKS */
  .amenities-section {
    background: white;
    padding: 100px 40px;
  }

  .amenity-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    margin-bottom: 100px;
    opacity: 0;
    transform: translateX(-60px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .amenity-block.from-left {
    transform: translateX(-60px);
  }

  .amenity-block.from-right {
    transform: translateX(60px);
  }

  .amenity-block.visible {
    opacity: 1;
    transform: translateX(0);
  }

  .amenity-block.reverse {
    direction: rtl;
  }

  .amenity-block.reverse > * {
    direction: ltr;
  }

  .amenity-image {
    overflow: hidden;
    border-radius: 4px;
  }

  .amenity-image img {
    display: block;
    width: 100%;
    height: 400px;
    object-fit: cover;
  }

  .amenity-text h3 {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.6rem;
    font-weight: 300;
    color: var(--ink);
    margin-bottom: 20px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .amenity-text p {
    font-family: 'Lato', Helvetica, Arial, sans-serif;
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 24px;
  }

  .amenity-features {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .amenity-features li {
    font-family: 'Lato', Helvetica, Arial, sans-serif;
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.8;
    color: var(--text-secondary);
  }

  /* QUICK REFERENCE CARDS */
  .cards-section {
    background: var(--paper);
    padding: 80px 40px;
    opacity: 0;
    transition: opacity 0.8s ease;
  }

  .cards-section.reveal {
    opacity: 1;
  }

  .cards-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 2.4rem;
    font-weight: 300;
    text-align: center;
    color: var(--ink);
    margin-bottom: 60px;
    letter-spacing: 0.05em;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .amenity-card {
    background: white;
    padding: 32px 20px;
    text-align: center;
    border-radius: 4px;
    font-family: 'Lato', Helvetica, Arial, sans-serif;
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--ink);
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .amenity-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
    background: var(--tan);
  }

  /* PARALLAX DIVIDER */
  .parallax-section {
    position: relative;
    height: 45vh;
    min-height: 400px;
    overflow: hidden;
  }

  .parallax-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
  }

  .parallax-overlay {
    position: absolute;
    inset: 0;
    background: rgba(30, 45, 58, 0.5);
  }

  /* FINAL CTA SECTION */
  .final-cta-section {
    background: var(--ink);
    padding: 80px 40px;
    text-align: center;
    opacity: 0;
    transition: opacity 0.8s ease;
  }

  .final-cta-section.reveal {
    opacity: 1;
  }

  .final-cta-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .final-cta-section h2 {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 2.4rem;
    font-weight: 300;
    color: white;
    margin-bottom: 32px;
    letter-spacing: 0.05em;
  }

  /* BUTTON STYLES */
  .btn {
    display: inline-block;
    font-family: 'Lato', Helvetica, Arial, sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    padding: 14px 36px;
    text-decoration: none;
    transition: all 0.3s ease;
    border-radius: 0;
    border: none;
    cursor: pointer;
  }

  .btn--primary {
    background-color: var(--ink);
    color: white;
  }

  .btn--primary:hover {
    background-color: var(--hover);
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .intro-section {
      padding: 60px 20px;
    }

    .intro-section h2 {
      font-size: 1.8rem;
    }

    .intro-section p {
      font-size: 0.9rem;
    }

    .amenities-section {
      padding: 60px 20px;
    }

    .amenity-block {
      grid-template-columns: 1fr;
      gap: 40px;
      margin-bottom: 60px;
    }

    .amenity-block.reverse {
      direction: ltr;
    }

    .amenity-image img {
      height: 280px;
    }

    .amenity-text h3 {
      font-size: 1.4rem;
    }

    .amenity-text p {
      font-size: 0.9rem;
    }

    .cards-section {
      padding: 60px 20px;
    }

    .cards-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 15px;
    }

    .amenity-card {
      padding: 24px 16px;
      font-size: 0.75rem;
    }

    .section-title {
      font-size: 1.8rem;
      margin-bottom: 40px;
    }

    .parallax-section {
      height: 35vh;
      min-height: 300px;
    }

    .parallax-bg {
      background-attachment: scroll;
    }

    .final-cta-section {
      padding: 60px 20px;
    }

    .final-cta-section h2 {
      font-size: 1.8rem;
    }
  }

  @media (max-width: 480px) {
    .cards-grid {
      grid-template-columns: 1fr;
    }

    .amenity-block.from-left {
      transform: translateX(0);
    }

    .amenity-block.from-right {
      transform: translateX(0);
    }
  }
</style>
