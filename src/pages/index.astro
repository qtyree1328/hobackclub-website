</style>

<script>
  // ========== CURTAIN REVEAL ANIMATION ==========
  const curtainLeft = document.querySelector('.curtain-left');
  const curtainRight = document.querySelector('.curtain-right');
  const heroVideo = document.querySelector('.hero-video');

  setTimeout(() => {
    curtainLeft?.classList.add('revealed');
    curtainRight?.classList.add('revealed');
    heroVideo?.classList.add('revealed');
  }, 300);

  // ========== GALLERY AUTO-SCROLL ==========
  const galleryTrack = document.getElementById('galleryTrack');
  if (galleryTrack) {
    let scrollAmount = 0;
    const slideWidth = 296; // 280px + 16px gap
    const speed = 0.5; // pixels per frame
    let isScrolling = true;

    const scroll = () => {
      if (isScrolling) {
        scrollAmount += speed;
        galleryTrack.style.transform = `translateX(-${scrollAmount}px)`;

        // Reset for infinite loop
        const maxScroll = slideWidth * 11 + 16 * 10; // 11 original slides + gaps
        if (scrollAmount > maxScroll) {
          scrollAmount = 0;
        }
      }
      requestAnimationFrame(scroll);
    };

    galleryTrack.addEventListener('mouseenter', () => { isScrolling = false; });
    galleryTrack.addEventListener('mouseleave', () => { isScrolling = true; });
    galleryTrack.addEventListener('touchstart', () => { isScrolling = false; });
    galleryTrack.addEventListener('touchend', () => { isScrolling = true; });

    scroll();
  }

  // ========== SHOWCASE PANEL INTERSECTION OBSERVER ==========
  const showcasePanels = document.querySelectorAll('.showcase-panel');
  const panelObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        panelObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.2 });

  showcasePanels.forEach(panel => panelObserver.observe(panel));

  // ========== SEASONS HOVER EFFECT ==========
  const seasonCards = document.querySelectorAll('.season-card');
  seasonCards.forEach((card, index) => {
    card.addEventListener('mouseenter', () => {
      seasonCards.forEach((c, i) => {
        if (i !== index) {
          c.style.opacity = '0.6';
        }
      });
    });
    card.addEventListener('mouseleave', () => {
      seasonCards.forEach(c => {
        c.style.opacity = '1';
      });
    });
  });

  // ========== CAROUSEL NAVIGATION ==========
  const carouselTrack = document.getElementById('carouselTrack');
  const dots = document.querySelectorAll('.dot');
  const prevBtn = document.querySelector('.carousel-prev');
  const nextBtn = document.querySelector('.carousel-next');

  let currentSlide = 0;
  const slides = document.querySelectorAll('.carousel-card');
  const totalSlides = 5;

  const updateCarousel = () => {
    const offset = -currentSlide * (50 + 2.5); // 50% width + gap
    carouselTrack.style.transform = `translateX(${offset}%)`;

    dots.forEach((dot, i) => {
      dot.classList.toggle('active', i === currentSlide);
    });
  };

  prevBtn?.addEventListener('click', () => {
    currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
    updateCarousel();
  });

  nextBtn?.addEventListener('click', () => {
    currentSlide = (currentSlide + 1) % totalSlides;
    updateCarousel();
  });

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      currentSlide = parseInt(dot.dataset.index);
      updateCarousel();
    });
  });

  // Touch/swipe support for carousel
  let touchStartX = 0;
  let touchEndX = 0;

  carouselTrack?.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].screenX;
  });

  carouselTrack?.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].screenX;
    if (touchStartX - touchEndX > 50) {
      nextBtn?.click();
    } else if (touchEndX - touchStartX > 50) {
      prevBtn?.click();
    }
  });

  updateCarousel();
</script>
