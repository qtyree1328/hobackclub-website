    border: 2px solid #1e2d3a;
  }

  .btn--outline:hover {
    background: #1e2d3a;
    color: #fff;
  }
</style>

<script>
  // ========== CURTAIN REVEAL ANIMATION (matches hoback-demo) ==========
  const mask = document.getElementById('heroMask');
  const heroText = document.getElementById('heroText');
  const scrollDown = document.getElementById('scrollDown');

  // Short delay so background image is visible first, then curtain opens
  setTimeout(() => { mask?.classList.add('open'); }, 300);
  // Text fades in after curtain finishes (0.8s)
  setTimeout(() => { heroText?.classList.add('visible'); }, 1100);
  // Scroll indicator after text
  setTimeout(() => { scrollDown?.classList.add('visible'); }, 1600);

  // ========== ENDLESS IMAGE GALLERY (matches hoback-demo) ==========
  (function() {
    const IMAGES = [
      { src: "https://hobackclub.com/images/dynamic/getImage.gif?ID=100196", scale: 1.3, aspect: 0.65 },
      { src: "https://hobackclub.com/images/dynamic/getImage.gif?ID=100149", scale: 1.4, aspect: 0.6 },
      { src: "https://hobackclub.com/images/dynamic/getImage.gif?ID=100151", scale: 0.8, aspect: 1.25 },
      { src: "https://hobackclub.com/images/dynamic/getImage.gif?ID=100195", scale: 0.85, aspect: 1.1 },
      { src: "https://hobackclub.com/images/dynamic/getImage.gif?ID=100152", scale: 1.6, aspect: 0.5 },
      { src: "https://hobackclub.com/images/dynamic/getImage.gif?ID=100156", scale: 0.9, aspect: 1.0 },
      { src: "https://hobackclub.com/images/dynamic/getImage.gif?ID=100167", scale: 1.3, aspect: 0.7 },
      { src: "https://hobackclub.com/images/dynamic/getImage.gif?ID=100192", scale: 1.1, aspect: 0.75 },
      { src: "https://hobackclub.com/images/dynamic/getImage.gif?ID=100170", scale: 0.75, aspect: 1.35 },
      { src: "https://hobackclub.com/images/dynamic/getImage.gif?ID=100169", scale: 1.5, aspect: 0.55 },
      { src: "https://hobackclub.com/images/dynamic/getImage.gif?ID=100172", scale: 1.0, aspect: 0.85 }
    ];

    const track = document.getElementById('hbGalleryTrack');
    const container = document.getElementById('hbGallery');
    if (!track || !container) return;

    const vw = window.innerWidth;
    const BASE = vw < 480 ? 100 : vw < 768 ? 150 : 380;
    const GAP = vw < 480 ? 10 : vw < 768 ? 14 : 32;

    function makeSlide(item) {
      const w = Math.round(BASE * (item.scale || 1));
      const s = document.createElement('div');
      s.className = 'hb-gallery__slide';
      s.style.width = w + 'px';
      s.style.height = Math.round(w * (item.aspect || 0.75)) + 'px';
      const img = document.createElement('img');
      img.src = item.src;
      img.alt = 'Hoback Club';
      img.loading = 'lazy';
      s.appendChild(img);
      return s;
    }

    // Create 3 copies for seamless loop
    for (let c = 0; c < 3; c++) {
      IMAGES.forEach(item => track.appendChild(makeSlide(item)));
    }

    const allSlides = track.querySelectorAll('.hb-gallery__slide');
    let oneSet = 0;
    for (let i = 0; i < IMAGES.length; i++) {
      oneSet += allSlides[i].offsetWidth + GAP;
    }

    // Start centered on 3rd image
    const startSlide = allSlides[2];
    if (startSlide) {
      container.scrollLeft = startSlide.offsetLeft - (container.offsetWidth / 2) + (startSlide.offsetWidth / 2);
    }

    let paused = false;
    let timer;
    const speed = 0.25;

    function drift() {
      if (!paused) {
        container.scrollLeft += speed;
        if (container.scrollLeft >= oneSet) container.scrollLeft -= oneSet;
      }
      requestAnimationFrame(drift);
    }
    requestAnimationFrame(drift);

    function pause() { paused = true; clearTimeout(timer); }
    function resume() { clearTimeout(timer); timer = setTimeout(() => { paused = false; }, 2000); }
    container.addEventListener('mouseenter', pause);
    container.addEventListener('mouseleave', resume);
    container.addEventListener('touchstart', pause, { passive: true });
    container.addEventListener('touchend', resume, { passive: true });
  })();

  // ========== SHOWCASE PANEL SCROLL REVEAL ==========
  const panels = document.querySelectorAll('.hb-panels__item');
  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-revealed');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    panels.forEach(p => observer.observe(p));
  } else {
    panels.forEach(p => p.classList.add('is-revealed'));
  }

  // ========== SEASONS HOVER EFFECT ==========
  const seasonCards = document.querySelectorAll('.season-card');
  seasonCards.forEach((card, index) => {
    card.addEventListener('mouseenter', () => {
      seasonCards.forEach((c, i) => {
        if (i !== index) {
          c.style.opacity = '0.6';
        }
      });
    });
    card.addEventListener('mouseleave', () => {
      seasonCards.forEach(c => {
        c.style.opacity = '1';
      });
    });
  });

  // ========== CAROUSEL NAVIGATION ==========
  const carouselTrack = document.getElementById('carouselTrack');
  const dots = document.querySelectorAll('.dot');
  const prevBtn = document.querySelector('.carousel-prev');
  const nextBtn = document.querySelector('.carousel-next');

  let currentSlide = 0;
  const slides = document.querySelectorAll('.carousel-card');
  const totalSlides = 5;

  const updateCarousel = () => {
    const offset = -currentSlide * (50 + 2.5); // 50% width + gap
    carouselTrack.style.transform = `translateX(${offset}%)`;

    dots.forEach((dot, i) => {
      dot.classList.toggle('active', i === currentSlide);
    });
  };

  prevBtn?.addEventListener('click', () => {
    currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
    updateCarousel();
  });

  nextBtn?.addEventListener('click', () => {
    currentSlide = (currentSlide + 1) % totalSlides;
    updateCarousel();
  });

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      currentSlide = parseInt(dot.dataset.index);
      updateCarousel();
    });
  });

  // Touch/swipe support for carousel
  let touchStartX = 0;
  let touchEndX = 0;

  carouselTrack?.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].screenX;
  });

  carouselTrack?.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].screenX;
    if (touchStartX - touchEndX > 50) {
      nextBtn?.click();
    } else if (touchEndX - touchStartX > 50) {
      prevBtn?.click();
    }
  });

  updateCarousel();
</script>
