---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/paths';
---

<BaseLayout title="Home" heroClass="homepage">
  <!-- SECTION 1: Video Hero with Curtain Reveal (matches hoback-demo) -->
  <section class="hero" id="heroSection">
    <div class="hero-mask" id="heroMask">
      <video autoplay muted loop playsinline id="heroVideo">
        <source src={withBase('/videos/Hoback_website_mov2.mp4')} type="video/mp4" />
      </video>
      <div class="hero-overlay"></div>
      <div class="hero-text" id="heroText">
        <h1>Hoback Club, Jackson Hole</h1>
      </div>
      <div class="scroll-down" id="scrollDown">
        <span></span>
      </div>
    </div>
  </section>

  <!-- SECTION 2: Weather Bar -->
  <section class="weather-section">
    <div class="weather-container">
      <div class="weather-header">
        <h3>Weather This Week</h3>
      </div>
      <div class="weather-days">
        <div class="weather-day">
          <div class="weather-day-name">Mon</div>
          <div class="weather-day-date">Apr 9</div>
          <div class="weather-day-temp">38°</div>
        </div>
        <div class="weather-day">
          <div class="weather-day-name">Tue</div>
          <div class="weather-day-date">Apr 10</div>
          <div class="weather-day-temp">42°</div>
        </div>
        <div class="weather-day">
          <div class="weather-day-name">Wed</div>
          <div class="weather-day-date">Apr 11</div>
          <div class="weather-day-temp">35°</div>
        </div>
        <div class="weather-day">
          <div class="weather-day-name">Thu</div>
          <div class="weather-day-date">Apr 12</div>
          <div class="weather-day-temp">40°</div>
        </div>
        <div class="weather-day">
          <div class="weather-day-name">Fri</div>
          <div class="weather-day-date">Apr 13</div>
          <div class="weather-day-temp">44°</div>
        </div>
      </div>
      <div class="weather-button">
        <a href={withBase('/mountain')} class="btn btn--outline">Mountain Conditions</a>
      </div>
    </div>
  </section>

  <!-- SECTION 3: Mountain Drawing Section -->
  <section class="mountain-section">
    <div class="mountain-container">
      <div class="mountain-image">
        <img src={withBase('/images/tetons_drawing4.png')} alt="Teton Mountains" />
      </div>
      <div class="mountain-content">
        <p class="mountain-kicker">Jackson Hole, Wyoming</p>
        <h2 class="mountain-title">Where the Mountains Meet Your Door</h2>
        <a href={withBase('/discover')} class="btn btn--primary">Learn More</a>
      </div>
    </div>
  </section>

  <!-- SECTION 4: Auto-Scrolling Image Gallery (matches hoback-demo) -->
  <section class="hb-gallery" id="hbGallery">
    <div class="hb-gallery__track" id="hbGalleryTrack">
      <!-- Slides generated by JS with 3x repeat for continuous scroll -->
    </div>
  </section>

  <!-- SECTION 5: Showcase Panels - Life at Hoback (continuous with gallery, same bg) -->
  <section class="hb-panels" id="hbPanels">
    <div class="hb-panels__header"><br></div>

    <!-- 01 — Ski Access -->
    <div class="hb-panels__item">
      <div class="hb-panels__img-wrap">
        <div class="hb-panels__img" style="background-image: url('https://jhskis.com/wp-content/uploads/2014/11/Ski1.jpg');"></div>
      </div>
      <div class="hb-panels__text">
        <span class="hb-panels__number">01</span>
        <div class="hb-panels__line"></div>
        <h2 class="hb-panels__heading">The Best Ski-In, Ski-Out Access in Jackson</h2>
        <p class="hb-panels__desc">Step directly from your residence onto pristine corduroy. The most coveted slope-side position at Jackson Hole Mountain Resort, where powder days begin at your front door.</p>
      </div>
    </div>

    <!-- 02 — Spa -->
    <div class="hb-panels__item">
      <div class="hb-panels__img-wrap">
        <div class="hb-panels__img" style="background-image: url('https://hobackclub.com/images/dynamic/getImage.gif?ID=100158');"></div>
      </div>
      <div class="hb-panels__text">
        <span class="hb-panels__number">02</span>
        <div class="hb-panels__line"></div>
        <h2 class="hb-panels__heading">World-Class Wellness &amp; Recovery Spa</h2>
        <p class="hb-panels__desc">Restore body and mind in our alpine sanctuary. From hydrotherapy pools to expert-guided recovery sessions, every detail is designed to rejuvenate after a day on the mountain.</p>
      </div>
    </div>

    <!-- 03 — Dining -->
    <div class="hb-panels__item">
      <div class="hb-panels__img-wrap">
        <div class="hb-panels__img" style="background-image: url('https://hobackclub.com/images/dynamic/getImage.gif?ID=100160');"></div>
      </div>
      <div class="hb-panels__text">
        <span class="hb-panels__number">03</span>
        <div class="hb-panels__line"></div>
        <h2 class="hb-panels__heading">Private Residence Dining, Locally Sourced</h2>
        <p class="hb-panels__desc">Savor cuisine crafted by our culinary team from the finest regional ingredients. From intimate fireside dinners to curated tasting events, every meal becomes an occasion.</p>
      </div>
    </div>

    <!-- 04 — Après -->
    <div class="hb-panels__item">
      <div class="hb-panels__img-wrap">
        <div class="hb-panels__img" style="background-image: url('https://hobackclub.com/images/dynamic/getImage.gif?ID=100159');"></div>
      </div>
      <div class="hb-panels__text">
        <span class="hb-panels__number">04</span>
        <div class="hb-panels__line"></div>
        <h2 class="hb-panels__heading">Indoor &amp; Outdoor Après Ski Lounges</h2>
        <p class="hb-panels__desc">Unwind fireside or beneath the stars. Thoughtfully designed gathering spaces that bring members together in effortless sophistication, from morning coffee to evening cocktails.</p>
      </div>
    </div>

    <!-- 05 — National Park -->
    <div class="hb-panels__item">
      <div class="hb-panels__img-wrap">
        <div class="hb-panels__img" style="background-image: url('https://hobackclub.com/images/dynamic/getImage.gif?ID=100125');"></div>
      </div>
      <div class="hb-panels__text">
        <span class="hb-panels__number">05</span>
        <div class="hb-panels__line"></div>
        <h2 class="hb-panels__heading">Direct Access to Grand Teton National Park</h2>
        <p class="hb-panels__desc">Your gateway to one of America's most iconic landscapes. Miles of pristine trails, untouched wilderness, and crystal waters begin where your doorstep ends.</p>
      </div>
    </div>
  </section>

  <!-- SECTION 6: Seasons Section -->
  <section class="seasons-section">
    <div class="seasons-container">
      <h2 class="seasons-title">Four Seasons of Extraordinary Living</h2>

      <div class="seasons-grid">
        <div class="season-card season-winter" data-season="winter">
          <div class="season-overlay"></div>
          <p class="season-name">Winter</p>
        </div>
        <div class="season-card season-spring" data-season="spring">
          <div class="season-overlay"></div>
          <p class="season-name">Spring</p>
        </div>
        <div class="season-card season-summer" data-season="summer">
          <div class="season-overlay"></div>
          <p class="season-name">Summer</p>
        </div>
        <div class="season-card season-fall" data-season="fall">
          <div class="season-overlay"></div>
          <p class="season-name">Fall</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 7: Card Carousel -->
  <section class="carousel-section">
    <div class="carousel-container">
      <div class="carousel-left">
        <h2 class="carousel-title">Explore Our Exclusive Club</h2>

        <div class="carousel-dots">
          <button class="dot active" data-index="0" aria-label="Slide 1"></button>
          <button class="dot" data-index="1" aria-label="Slide 2"></button>
          <button class="dot" data-index="2" aria-label="Slide 3"></button>
          <button class="dot" data-index="3" aria-label="Slide 4"></button>
          <button class="dot" data-index="4" aria-label="Slide 5"></button>
        </div>

        <div class="carousel-controls">
          <button class="carousel-arrow carousel-prev" aria-label="Previous slide">←</button>
          <button class="carousel-arrow carousel-next" aria-label="Next slide">→</button>
        </div>
      </div>

      <div class="carousel-right">
        <div class="carousel-track" id="carouselTrack">
          <div class="carousel-card" style={`background-image: url('${withBase('/images/card-discover.jpg')}');`}>
            <div class="carousel-card-overlay"></div>
            <h3><a href={withBase('/discover')}>Discover Us</a></h3>
          </div>
          <div class="carousel-card" style={`background-image: url('${withBase('/images/card-stay.jpg')}');`}>
            <div class="carousel-card-overlay"></div>
            <h3><a href={withBase('/stay')}>Come & Stay</a></h3>
          </div>
          <div class="carousel-card" style={`background-image: url('${withBase('/images/card-amenities.jpg')}');`}>
            <div class="carousel-card-overlay"></div>
            <h3><a href={withBase('/amenities')}>Amenities</a></h3>
          </div>
          <div class="carousel-card" style={`background-image: url('${withBase('/images/card-winter.jpg')}');`}>
            <div class="carousel-card-overlay"></div>
            <h3><a href={withBase('/mountain')}>Winter Activities</a></h3>
          </div>
          <div class="carousel-card" style={`background-image: url('${withBase('/images/card-summer.jpg')}');`}>
            <div class="carousel-card-overlay"></div>
            <h3><a href={withBase('/lifestyle')}>Summer Activities</a></h3>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 8: Reserve Your Stay -->
  <section class="reserve-section">
    <div class="reserve-container">
      <div class="reserve-content">
        <h2 class="reserve-title">Reserve Your Stay</h2>
        <p class="reserve-description">Begin your mountain retreat today. Contact our hospitality team to plan your perfect Hoback experience.</p>
        <a href={withBase('/stay')} class="btn btn--primary">Inquire About a Stay</a>
      </div>
      <div class="reserve-image">
        <img src={withBase('/images/Jackson_tram.png')} alt="Jackson Hole Tram" />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ========== HERO SECTION (clip-path mask reveal, matches hoback-demo) ========== */
  .hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
    background: url('https://hobackclub.com/images/dynamic/getImage.gif?ID=100032') center/cover no-repeat;
  }

  .hero-mask {
    position: absolute;
    inset: 0;
    clip-path: polygon(50% 0%, 50% 0%, 50% 100%, 50% 100%);
    overflow: hidden;
  }

  .hero-mask.open {
    animation: maskReveal 0.8s cubic-bezier(.76,.09,.215,1) forwards;
  }

  @keyframes maskReveal {
    to { clip-path: polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%); }
  }

  .hero-mask video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.05);
  }

  .hero-mask.open video {
    animation: videoSettle 2s ease-out forwards;
  }

  @keyframes videoSettle {
    to { transform: scale(1); }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(30,45,58,0.65) 0%,
      rgba(30,45,58,0.2) 40%,
      transparent 100%
    );
    pointer-events: none;
    opacity: 0;
  }

  .hero-mask.open .hero-overlay {
    animation: heroFadeIn 2s ease-out forwards;
  }

  @keyframes heroFadeIn {
    to { opacity: 1; }
  }

  .hero-text {
    position: absolute;
    bottom: 80px;
    left: 0;
    right: 0;
    text-align: center;
    z-index: 2;
    opacity: 0;
    transform: translateY(20%);
  }

  .hero-text.visible {
    animation: heroFadeInUp 0.6s ease forwards;
  }

  @keyframes heroFadeInUp {
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-text h1 {
    color: #fff;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 3.2rem;
    font-weight: 300;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    margin: 0;
  }

  .scroll-down {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    color: #fff;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    opacity: 0;
  }

  .scroll-down.visible {
    animation: heroFadeIn 0.5s ease forwards;
  }

  .scroll-down span {
    display: inline-block;
    width: 1px;
    height: 30px;
    background: #fff;
    animation: scrollPulse 2s infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.5); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  @media (max-width: 768px) {
    .hero { min-height: 400px; }
    .hero-text h1 { font-size: 1.8rem; letter-spacing: 0.15em; }
    .hero-text { bottom: 60px; }
  }

  /* ========== WEATHER SECTION ========== */
  .weather-section {
    background: #f7f5f2;
    padding: 40px 20px;
  }

  .weather-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }

  .weather-header {
    flex-shrink: 0;
  }

  .weather-header h3 {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 300;
    color: #1e2d3a;
    margin: 0;
    white-space: nowrap;
  }

  .weather-days {
    display: flex;
    gap: 30px;
    flex: 1;
    justify-content: center;
  }

  .weather-day {
    text-align: center;
  }

  .weather-day-name {
    font-family: 'Lato', Helvetica, Arial, sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #7a8d98;
    margin-bottom: 4px;
  }

  .weather-day-date {
    font-family: 'Lato', Helvetica, Arial, sans-serif;
    font-size: 0.85rem;
    font-weight: 300;
    color: #666;
    margin-bottom: 8px;
  }

  .weather-day-temp {
    font-family: 'Lato', Helvetica, Arial, sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #1e2d3a;
  }

  .weather-button {
    flex-shrink: 0;
  }

  @media (max-width: 1024px) {
    .weather-container {
      flex-wrap: wrap;
      gap: 20px;
    }
    .weather-days {
      gap: 15px;
    }
  }

  @media (max-width: 768px) {
    .weather-section {
      padding: 30px 20px;
    }
    .weather-container {
      flex-direction: column;
      gap: 20px;
    }
    .weather-header h3 {
      font-size: 1.2rem;
    }
    .weather-days {
      width: 100%;
      gap: 10px;
    }
  }

  /* ========== MOUNTAIN SECTION ========== */
  .mountain-section {
    background: #ede9e1;
    padding: 80px 40px;
  }

  .mountain-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 60px;
  }

  .mountain-image {
    flex: 0 0 50%;
    margin-left: -80px;
  }

  .mountain-image img {
    width: 100%;
    height: auto;
    display: block;
    opacity: 0.55;
  }

  .mountain-content {
    flex: 1;
  }

  .mountain-kicker {
    font-family: 'Lato', Helvetica, Arial, sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #7a8d98;
    margin: 0 0 16px;
  }

  .mountain-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 2.5rem;
    font-weight: 300;
    color: #1e2d3a;
    margin: 0 0 30px;
    line-height: 1.3;
  }

  @media (max-width: 1024px) {
    .mountain-container {
      flex-direction: column;
      gap: 40px;
    }
    .mountain-image {
      flex: 1;
      margin-left: 0;
      width: 100%;
    }
    .mountain-content {
      width: 100%;
    }
  }

  @media (max-width: 768px) {
    .mountain-section {
      padding: 50px 20px;
    }
    .mountain-title {
      font-size: 1.8rem;
    }
  }

  /* ========== IMAGE GALLERY (matches hoback-demo) ========== */
  .hb-gallery {
    background: #ede9e1;
    padding: 30px 0 40px;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .hb-gallery::-webkit-scrollbar { display: none; }
  .hb-gallery__track {
    display: flex;
    align-items: center;
    gap: 32px;
    padding: 0;
    width: max-content;
  }
  .hb-gallery__slide {
    flex-shrink: 0;
    border-radius: 10px;
    overflow: hidden;
  }
  .hb-gallery__slide img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .hb-gallery { padding: 12px 0 20px; }
    .hb-gallery__track { gap: 10px; }
  }

  /* ========== SHOWCASE PANELS (matches hoback-demo, same tan bg) ========== */
  .hb-panels {
    background: #ede9e1;
  }
  .hb-panels__header {
    padding: 80px 6% 20px;
  }
  .hb-panels__item {
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 60px 6%;
    gap: 5%;
  }
  .hb-panels__item:nth-child(odd) { flex-direction: row-reverse; }
  .hb-panels__img-wrap {
    position: relative;
    flex: 0 0 38%;
    overflow: hidden;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .hb-panels__item.is-revealed .hb-panels__img-wrap {
    opacity: 1;
    transform: translateY(0);
  }
  .hb-panels__img-wrap::before {
    content: '';
    display: block;
    padding-top: 70%;
  }
  .hb-panels__img {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
  }
  .hb-panels__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 40px 0;
    position: relative;
    color: #1e2d3a;
  }
  .hb-panels__number {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(8rem, 14vw, 18rem);
    font-weight: 300;
    line-height: 1;
    color: rgba(30,45,58,0.04);
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0;
    transition: opacity 0.8s ease 0.15s;
    pointer-events: none;
    white-space: nowrap;
  }
  .hb-panels__item.is-revealed .hb-panels__number { opacity: 1; }
  .hb-panels__line {
    width: 70px;
    height: 1px;
    background: linear-gradient(90deg, rgba(30,45,58,0.35), rgba(30,45,58,0));
    margin-bottom: 20px;
    opacity: 0;
    transition: opacity 0.8s ease 0.2s;
  }
  .hb-panels__item.is-revealed .hb-panels__line { opacity: 1; }
  .hb-panels__heading {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(2.8rem, 3.5vw, 4.6rem);
    font-weight: 300;
    line-height: 1.15;
    color: #1e2d3a;
    position: relative;
    z-index: 2;
    margin: 0;
    opacity: 0;
    transform: translateY(15px);
    transition: opacity 0.7s ease 0.2s, transform 0.7s ease 0.2s;
  }
  .hb-panels__item.is-revealed .hb-panels__heading {
    opacity: 1;
    transform: translateY(0);
  }
  .hb-panels__desc {
    font-family: 'Lato', Helvetica, Arial, sans-serif;
    font-size: clamp(1.15rem, 1.5vw, 1.55rem);
    font-weight: 300;
    line-height: 1.75;
    max-width: 480px;
    margin: 16px 0 0;
    color: rgba(30,45,58,0.78);
    position: relative;
    z-index: 2;
    opacity: 0;
    transform: translateY(15px);
    transition: opacity 0.7s ease 0.35s, transform 0.7s ease 0.35s;
  }
  .hb-panels__item.is-revealed .hb-panels__desc {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 900px) {
    .hb-panels__item { flex-direction: column !important; padding: 40px 6%; gap: 0; }
    .hb-panels__img-wrap { flex: none; width: 100%; }
    .hb-panels__img-wrap::before { padding-top: 60%; }
    .hb-panels__text { flex: none; padding: 30px 0 0; }
    .hb-panels__number { font-size: clamp(6rem, 20vw, 12rem); }
  }
  @media (max-width: 768px) {
    .hb-panels__header { padding: 50px 24px 14px; }
    .hb-panels__item { padding: 36px 24px; }
    .hb-panels__heading { font-size: clamp(1.8rem, 6vw, 2.6rem); }
    .hb-panels__desc { font-size: 1rem; max-width: 100%; }
    .hb-panels__line { width: 50px; margin-bottom: 14px; }
  }

  /* ========== SEASONS SECTION ========== */
  .seasons-section {
    background: #fff;
    padding: 100px 40px;
  }

  .seasons-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .seasons-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 2.5rem;
    font-weight: 300;
    color: #1e2d3a;
    text-align: center;
    margin-bottom: 60px;
  }

  .seasons-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    height: 400px;
  }

  .season-card {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    cursor: pointer;
    background-size: cover;
    background-position: center;
    flex: 1;
    transition: flex 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .season-winter {
    background-image: url('https://hobackclub.com/images/dynamic/getImage.gif?ID=100032');
  }

  .season-spring {
    background-image: url('https://hobackclub.com/images/dynamic/getImage.gif?ID=100077');
  }

  .season-summer {
    background-image: url('https://hobackclub.com/images/dynamic/getImage.gif?ID=100120');
  }

