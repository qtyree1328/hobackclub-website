  <script slot="scripts">
    // Flyover Video: Start playing on scroll into view
    const flyoverVideo = document.getElementById('flyoverVideo');

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            flyoverVideo.play();
          } else {
            flyoverVideo.pause();
          }
        });
      },
      { threshold: 0.25 }
    );

    if (flyoverVideo) {
      observer.observe(flyoverVideo);
    }

    // Valley Accordion
    const accordionItems = document.querySelectorAll('.accordion-item');

    accordionItems.forEach((item) => {
      const trigger = item.querySelector('.accordion-trigger');
      const content = item.querySelector('.accordion-content');

      trigger.addEventListener('click', () => {
        // Close all other items
        accordionItems.forEach((otherItem) => {
          if (otherItem !== item) {
            otherItem.querySelector('.accordion-content').classList.remove('is-active');
          }
        });

        // Toggle current item
        content.classList.toggle('is-active');
      });
    });

    // SVG Progress Ring Animation
    const rings = document.querySelectorAll('.progress-ring-circle, .progress-ring-circle--amber');
    rings.forEach((circle) => {
      const circumference = 2 * Math.PI * 54;
      circle.style.strokeDasharray = circumference;

      // Animate on load
      setTimeout(() => {
        circle.style.transition = 'stroke-dashoffset 2s ease';
      }, 100);
    });
  </script>
