---
// Footer.astro - 2-panel footer matching Mailchimp closing style
import { withBase } from '../utils/paths';

const pageLinks = [
  { href: '/discover', label: 'Discover Us' },
  { href: '/stay', label: 'Come & Stay' },
  { href: '/amenities', label: 'Amenities' },
  { href: '/mountain', label: 'Mountain' },
  { href: '/lifestyle', label: 'Lifestyle' },
  { href: '/membership', label: 'Membership' },
  { href: '/contact', label: 'Contact Us' },
  { href: 'https://members.hobackclub.com', label: 'Member Login', external: true },
];
---

<footer>
  <!-- Panel 1: Mountain drawing (left) / CTA text (right) — tan background -->
  <div class="footer-cta">
    <div class="footer-cta-inner">
      <div class="footer-cta-drawing">
        <img src={withBase('/images/tetons_drawing4.png')} alt="" />
      </div>
      <div class="footer-cta-text">
        <h2 class="footer-cta-heading">Questions or Special Requests?</h2>
        <p class="footer-cta-body">
          Contact us at <a href="tel:+13072495943" class="footer-phone">(307) 249-5943</a> or email <a href="mailto:concierge@hobackclub.com" class="footer-phone">concierge@hobackclub.com</a>
        </p>
        <a href={withBase('/contact')} class="footer-cta-btn">Get in Touch</a>
      </div>
    </div>
  </div>

  <!-- Panel 2: Links + Legal — dark background -->
  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <div class="footer-logo">
        <a href={withBase('/')}>
          <img src={withBase('/images/logo-footer.svg')} alt="Hoback Club" />
        </a>
      </div>
      <div class="footer-club-info">
        <span class="footer-club-name">HOBACK CLUB</span>
        <span class="footer-club-location">Jackson Hole, Wyoming</span>
        <span class="footer-club-address">P.O. Box 158, Teton Village, WY 83025</span>
        <span class="footer-club-contact">
          <a href="tel:+13072495943">(307) 249-5943</a> &middot; <a href="mailto:concierge@hobackclub.com">concierge@hobackclub.com</a>
        </span>
      </div>
      <nav class="footer-nav">
        {pageLinks.map(link => (
          <a
            href={link.external ? link.href : withBase(link.href)}
            {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >{link.label}</a>
        ))}
      </nav>
      <div class="footer-legal">
        <span>&copy; {new Date().getFullYear()} Hoback Club. All Rights Reserved.</span>
      </div>
    </div>
    <button class="back-to-top" onclick="window.scrollTo({top:0,behavior:'smooth'})" aria-label="Back to top">&uarr;</button>
  </div>
</footer>

<style>
  footer {
    margin: 0;
    padding: 0;
  }

  /* ===== PANEL 1: TAN CTA SECTION ===== */
  .footer-cta {
    background: #ede9e1;
    padding: 50px 40px;
  }
  .footer-cta-inner {
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 40px;
  }
  .footer-cta-text {
    flex: 1;
  }
  .footer-cta-heading {
    font-family: 'Cormorant Garamond', Georgia, 'Times New Roman', serif;
    font-size: 26px;
    font-weight: 300;
    color: #1e2d3a;
    line-height: 1.25;
    margin: 0 0 12px;
  }
  .footer-cta-body {
    font-family: 'Lato', Helvetica, Arial, sans-serif;
    font-size: 14px;
    font-weight: 300;
    color: #666;
    line-height: 1.7;
    margin: 0 0 24px;
  }
  .footer-phone {
    color: #1e2d3a;
    text-decoration: none;
    font-weight: 700;
  }
  .footer-phone:hover {
    text-decoration: underline;
  }
  .footer-cta-btn {
    display: inline-block;
    font-family: 'Lato', Helvetica, Arial, sans-serif;
    font-size: 11px;
    font-weight: 700;
    color: #fff;
    background: #1e2d3a;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 3px;
    padding: 12px 32px;
    transition: background 0.3s;
  }
  .footer-cta-btn:hover {
    background: #0d1a24;
  }
  .footer-cta-drawing {
    flex: 0 0 300px;
    text-align: left;
  }
  .footer-cta-drawing img {
    display: block;
    width: 300px;
    height: auto;
    opacity: 0.15;
  }

  /* ===== PANEL 2: DARK BOTTOM BAR ===== */
  .footer-bottom {
    background: #1e2d3a;
    padding: 40px 40px 30px;
    position: relative;
  }
  .footer-bottom-inner {
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }
  .footer-logo img {
    height: 80px;
    width: auto;
    opacity: 0.8;
  }

  /* Club info block */
  .footer-club-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    font-family: 'Lato', Helvetica, Arial, sans-serif;
    color: rgba(255, 255, 255, 0.55);
  }
  .footer-club-name {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.7);
  }
  .footer-club-location {
    font-size: 0.75rem;
    font-weight: 300;
    font-style: italic;
  }
  .footer-club-address {
    font-size: 0.68rem;
    font-weight: 300;
  }
  .footer-club-contact {
    font-size: 0.68rem;
    font-weight: 300;
  }
  .footer-club-contact a {
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    transition: color 0.3s;
  }
  .footer-club-contact a:hover {
    color: #fff;
  }

  /* Page links row */
  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 28px;
  }
  .footer-nav a {
    font-family: 'Lato', Helvetica, Arial, sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    transition: color 0.3s;
  }
  .footer-nav a:hover {
    color: #fff;
  }

  /* Legal line */
  .footer-legal {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 6px 20px;
    font-family: 'Lato', Helvetica, Arial, sans-serif;
    font-size: 0.68rem;
    color: rgba(255, 255, 255, 0.35);
  }

  /* Back to top */
  .back-to-top {
    position: absolute;
    right: 40px;
    bottom: 30px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: transparent;
    color: rgba(255, 255, 255, 0.5);
    font-size: 1rem;
    cursor: pointer;
    transition: border-color 0.3s, color 0.3s;
  }
  .back-to-top:hover {
    border-color: rgba(255, 255, 255, 0.5);
    color: #fff;
  }

  /* ===== MOBILE ===== */
  @media (max-width: 768px) {
    .footer-cta {
      padding: 40px 20px;
    }
    .footer-cta-inner {
      flex-direction: column;
      text-align: center;
    }
    .footer-cta-drawing {
      flex: 1;
      text-align: center;
    }
    .footer-cta-drawing img {
      margin: 0 auto;
      width: 200px;
    }
    .footer-bottom {
      padding: 30px 20px 24px;
    }
    .footer-nav {
      gap: 6px 16px;
    }
    .footer-nav a {
      font-size: 0.65rem;
    }
    .back-to-top {
      right: 20px;
      bottom: 24px;
    }
  }
</style>
